{
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/deny-python-pytest.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path'); [[ \"$FILE\" == *.typ ]] && cjk-space-formatter -i \"$FILE\" || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --style=powerline --theme=tokyo-night",
    "padding": 0
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "generate-conventional-commits-messages@generate-conventional-commits-messages": true,
    "pr-review-automation-skill@pr-review-automation-skill": true,
    "research-and-implement@research-and-implement": true,
    "hpc@hpc": true
  },
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
