{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "includeCoAuthoredBy": false,
  "attribution": {
    "sessionUrl": false
  },
  "permissions": {
    "allow": [
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr status:*)",
      "Bash(gh repo view:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(pbcopy)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "Read(//opt/homebrew/**)",
      "Read(~/ghq/**)",
      "Read(~/gwq/**)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "WebSearch",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo doc:*)",
      "Bash(cargo tree:*)",
      "Bash(cargo run:*)",
      "Bash(cargo bench:*)",
      "Bash(cargo clean:*)",
      "Bash(cargo mutants:*)",
      "Bash(typst compile:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv build:*)"
    ],
    "deny": [
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(conda:*)",
      "Bash(mamba:*)",
      "Bash(micromamba:*)",
      "Bash(pixi:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/deny-direct-python.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/deny-gh-direct-body.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-broad-fs-scan.py"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-rg-replace-confusion.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-suppress.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path'); [[ \"$FILE\" == *.typ ]] && cjk-space-formatter -i \"$FILE\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/detect-leaked-toolcall.py",
            "statusMessage": "Checking for leaked tool-call markup"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/detect-leaked-toolcall.py",
            "statusMessage": "Checking for leaked tool-call markup"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --style=powerline --theme=tokyo-night",
    "padding": 0
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true,
  "agentPushNotifEnabled": true
}
